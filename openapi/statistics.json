{
  "openapi": "3.1.0",
  "info": {
    "title": "Statistics Service API",
    "description": "Statistics projection query API",
    "contact": { "name": "Team Management Backend" },
    "license": { "name": "Proprietary" },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8086",
      "description": "Local Statistics Service"
    }
  ],
  "tags": [
    { "name": "Statistics", "description": "Statistics projection query APIs" }
  ],
  "paths": {
    "/api/statistics/teams": {
      "get": {
        "tags": ["Statistics"],
        "summary": "List team standings",
        "description": "List projected team standings for a season and tournament",
        "operationId": "teams",
        "parameters": [
          {
            "name": "season",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tournamentId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListTeamStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/statistics/players": {
      "get": {
        "tags": ["Statistics"],
        "summary": "List player statistics",
        "description": "List projected player statistics with season, tournament, pagination and sorting parameters",
        "operationId": "players",
        "parameters": [
          {
            "name": "season",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tournamentId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32", "default": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32", "default": 20 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "goalInvolvements" }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponsePlayerStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/statistics/matches": {
      "get": {
        "tags": ["Statistics"],
        "summary": "List match statistics",
        "description": "List projected match summaries with pagination",
        "operationId": "matches",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32", "default": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32", "default": 20 }
          },
          {
            "name": "tournamentId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseMatchSummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/statistics/leaderboards": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get leaderboard",
        "description": "Get a leaderboard for the selected metric, season and tournament",
        "operationId": "leaderboards",
        "parameters": [
          {
            "name": "boardType",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "season",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tournamentId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "topN",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListLeaderboardResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/statistics/health": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get statistics health",
        "description": "Return a lightweight statistics-service health response",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/statistics/dashboard": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get dashboard",
        "description": "Get the cached dashboard statistics summary",
        "operationId": "dashboard",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseDashboardStatisticsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Statistics API error response",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request succeeded",
            "example": false
          },
          "data": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Error details keyed by field or message",
            "example": { "message": "Invalid boardType" }
          }
        }
      },
      "ApiResponseListTeamStatsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TeamStatsResponse" }
          }
        }
      },
      "TeamStatsResponse": {
        "type": "object",
        "description": "Team statistics response",
        "properties": {
          "rankNo": {
            "type": "integer",
            "format": "int32",
            "description": "Rank number",
            "example": 1
          },
          "teamId": {
            "type": "integer",
            "format": "int64",
            "description": "Team ID",
            "example": 1
          },
          "teamName": {
            "type": "string",
            "description": "Team name",
            "example": "Team A"
          },
          "played": {
            "type": "integer",
            "format": "int32",
            "description": "Played matches",
            "example": 12
          },
          "win": {
            "type": "integer",
            "format": "int32",
            "description": "Wins",
            "example": 8
          },
          "draw": {
            "type": "integer",
            "format": "int32",
            "description": "Draws",
            "example": 2
          },
          "lose": {
            "type": "integer",
            "format": "int32",
            "description": "Losses",
            "example": 2
          },
          "goalsFor": {
            "type": "integer",
            "format": "int32",
            "description": "Goals for",
            "example": 25
          },
          "goalsAgainst": {
            "type": "integer",
            "format": "int32",
            "description": "Goals against",
            "example": 11
          },
          "goalDiff": {
            "type": "integer",
            "format": "int32",
            "description": "Goal difference",
            "example": 14
          },
          "points": {
            "type": "integer",
            "format": "int32",
            "description": "Points",
            "example": 26
          },
          "season": {
            "type": "string",
            "description": "Season label",
            "example": "2026"
          },
          "tournamentId": {
            "type": "integer",
            "format": "int64",
            "description": "Tournament ID",
            "example": 1
          },
          "tournamentName": {
            "type": "string",
            "description": "Tournament name",
            "example": "Summer League"
          }
        }
      },
      "ApiResponsePagedResponsePlayerStatsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "$ref": "#/components/schemas/PagedResponsePlayerStatsResponse"
          }
        }
      },
      "PagedResponsePlayerStatsResponse": {
        "type": "object",
        "description": "Generic page response",
        "properties": {
          "content": {
            "type": "array",
            "description": "Page content",
            "items": { "$ref": "#/components/schemas/PlayerStatsResponse" }
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "description": "Current zero-based page index",
            "example": 0
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "description": "Page size",
            "example": 20
          },
          "totalElements": {
            "type": "integer",
            "format": "int64",
            "description": "Total element count",
            "example": 42
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "description": "Total page count",
            "example": 3
          }
        }
      },
      "PlayerStatsResponse": {
        "type": "object",
        "description": "Player statistics response",
        "properties": {
          "playerId": {
            "type": "integer",
            "format": "int64",
            "description": "Player ID",
            "example": 10
          },
          "playerName": {
            "type": "string",
            "description": "Player name",
            "example": "Alice"
          },
          "season": {
            "type": "string",
            "description": "Season label",
            "example": "2026"
          },
          "tournamentId": {
            "type": "integer",
            "format": "int64",
            "description": "Tournament ID",
            "example": 1
          },
          "tournamentName": {
            "type": "string",
            "description": "Tournament name",
            "example": "Summer League"
          },
          "appearances": {
            "type": "integer",
            "format": "int32",
            "description": "Appearance count",
            "example": 12
          },
          "starts": {
            "type": "integer",
            "format": "int32",
            "description": "Start count",
            "example": 10
          },
          "goals": {
            "type": "integer",
            "format": "int32",
            "description": "Goal count",
            "example": 8
          },
          "assists": {
            "type": "integer",
            "format": "int32",
            "description": "Assist count",
            "example": 5
          },
          "goalInvolvements": {
            "type": "integer",
            "format": "int32",
            "description": "Goals plus assists",
            "example": 13
          }
        }
      },
      "ApiResponsePagedResponseMatchSummaryResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "$ref": "#/components/schemas/PagedResponseMatchSummaryResponse"
          }
        }
      },
      "MatchSummaryResponse": {
        "type": "object",
        "description": "Match statistics summary response",
        "properties": {
          "matchId": {
            "type": "integer",
            "format": "int64",
            "description": "Match ID",
            "example": 1
          },
          "tournamentId": {
            "type": "integer",
            "format": "int64",
            "description": "Tournament ID",
            "example": 1
          },
          "tournamentName": {
            "type": "string",
            "description": "Tournament name",
            "example": "Summer League"
          },
          "season": {
            "type": "string",
            "description": "Season label",
            "example": "2026"
          },
          "matchTime": {
            "type": "string",
            "format": "date-time",
            "description": "Match time",
            "example": "2026-06-01T20:00:00Z"
          },
          "opponentTeamName": {
            "type": "string",
            "description": "Opponent team name",
            "example": "Team B"
          },
          "homeAway": {
            "type": "string",
            "description": "Home or away value",
            "example": "HOME"
          },
          "ourScore": {
            "type": "integer",
            "format": "int32",
            "description": "Our score",
            "example": 2
          },
          "opponentScore": {
            "type": "integer",
            "format": "int32",
            "description": "Opponent score",
            "example": 1
          },
          "matchStatus": {
            "type": "string",
            "description": "Match status",
            "example": "FINISHED"
          },
          "finished": {
            "type": "boolean",
            "description": "Whether the match is finished",
            "example": true
          }
        }
      },
      "PagedResponseMatchSummaryResponse": {
        "type": "object",
        "description": "Generic page response",
        "properties": {
          "content": {
            "type": "array",
            "description": "Page content",
            "items": { "$ref": "#/components/schemas/MatchSummaryResponse" }
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "description": "Current zero-based page index",
            "example": 0
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "description": "Page size",
            "example": 20
          },
          "totalElements": {
            "type": "integer",
            "format": "int64",
            "description": "Total element count",
            "example": 42
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "description": "Total page count",
            "example": 3
          }
        }
      },
      "ApiResponseListLeaderboardResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LeaderboardResponse" }
          }
        }
      },
      "LeaderboardResponse": {
        "type": "object",
        "description": "Leaderboard entry response",
        "properties": {
          "rankNo": {
            "type": "integer",
            "format": "int32",
            "description": "Rank number",
            "example": 1
          },
          "entityId": {
            "type": "integer",
            "format": "int64",
            "description": "Ranked entity ID",
            "example": 10
          },
          "entityName": {
            "type": "string",
            "description": "Ranked entity name",
            "example": "Alice"
          },
          "metricValue": {
            "type": "integer",
            "format": "int32",
            "description": "Metric value",
            "example": 8
          },
          "boardType": {
            "type": "string",
            "description": "Leaderboard board type",
            "enum": ["SCORER", "ASSIST", "APPEARANCE", "GOAL_INVOLVEMENT"],
            "example": "GOALS"
          },
          "season": {
            "type": "string",
            "description": "Season label",
            "example": "2026"
          },
          "tournamentId": {
            "type": "integer",
            "format": "int64",
            "description": "Tournament ID",
            "example": 1
          },
          "appearanceCount": {
            "type": "integer",
            "format": "int32",
            "description": "Appearance count",
            "example": 12
          }
        }
      },
      "ApiResponseDashboardStatisticsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "$ref": "#/components/schemas/DashboardStatisticsResponse" }
        }
      },
      "DashboardStatisticsResponse": {
        "type": "object",
        "description": "Dashboard statistics response",
        "properties": {
          "totalMatches": {
            "type": "integer",
            "format": "int32",
            "description": "Total matches",
            "example": 12
          },
          "wins": {
            "type": "integer",
            "format": "int32",
            "description": "Wins",
            "example": 8
          },
          "draws": {
            "type": "integer",
            "format": "int32",
            "description": "Draws",
            "example": 2
          },
          "losses": {
            "type": "integer",
            "format": "int32",
            "description": "Losses",
            "example": 2
          },
          "goals": {
            "type": "integer",
            "format": "int32",
            "description": "Goals scored",
            "example": 25
          },
          "goalsAgainst": {
            "type": "integer",
            "format": "int32",
            "description": "Goals conceded",
            "example": 11
          },
          "topScorer": {
            "type": "string",
            "description": "Top scorer name",
            "example": "Alice"
          },
          "topScorerGoals": {
            "type": "integer",
            "format": "int32",
            "description": "Top scorer goal count",
            "example": 9
          },
          "topAssist": {
            "type": "string",
            "description": "Top assist provider name",
            "example": "Bob"
          },
          "topAssistCount": {
            "type": "integer",
            "format": "int32",
            "description": "Top assist count",
            "example": 6
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "name": "Authorization",
        "in": "header",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
