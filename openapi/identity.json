  "components": {
    "schemas": {
      "UpdateUserRolesRequest": {
        "type": "object",
        "description": "Update user roles request",
        "properties": {
          "roles": {
            "type": "array",
            "description": "Replacement role codes",
            "example": ["PLAYER"],
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "roleCodes": {
            "type": "array",
            "description": "Backward-compatible replacement role code alias",
            "example": ["PLAYER"],
            "items": { "type": "string" },
            "uniqueItems": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Identity API error response",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request succeeded",
            "example": false
          },
          "errorCode": {
            "type": "string",
            "description": "Machine-readable error code",
            "example": "ACCESS_DENIED"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Access denied"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Error timestamp"
          },
          "details": {
            "type": "array",
            "description": "Additional validation or business error details",
            "items": { "type": "string" }
          }
        }
      },
      "UserManagementResponse": {
        "type": "object",
        "description": "User management response",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "User ID",
            "example": 1
          },
          "username": {
            "type": "string",
            "description": "Username",
            "example": "coach"
          },
          "displayName": {
            "type": "string",
            "description": "Display name",
            "example": "Coach One"
          },
          "status": {
            "type": "string",
            "description": "User status",
            "enum": ["ACTIVE", "DISABLED", "LOCKED"],
            "example": "ACTIVE"
          },
          "roles": {
            "type": "array",
            "description": "Assigned role codes",
            "example": ["ROLE_COACH"],
            "items": { "type": "string" }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation time",
            "example": "2026-06-01T10:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update time",
            "example": "2026-06-01T11:00:00Z"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "description": "Create user request",
        "properties": {
          "username": {
            "type": "string",
            "description": "Username",
            "example": "coach2",
            "maxLength": 50,
            "minLength": 3
          },
          "password": {
            "type": "string",
            "description": "Initial password",
            "example": "123456",
            "maxLength": 100,
            "minLength": 6
          },
          "displayName": {
            "type": "string",
            "description": "Display name",
            "example": "Coach Two",
            "maxLength": 100,
            "minLength": 1
          },
          "roles": {
            "type": "array",
            "description": "Role codes",
            "example": ["COACH"],
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "roleCodes": {
            "type": "array",
            "description": "Backward-compatible role code alias",
            "example": ["COACH"],
            "items": { "type": "string" },
            "uniqueItems": true
          }
        },
        "required": ["displayName", "password", "username"]
      },
      "ResetPasswordRequest": {
        "type": "object",
        "description": "Reset password request",
        "properties": {
          "password": {
            "type": "string",
            "description": "New password",
            "example": "123456",
            "maxLength": 100,
            "minLength": 6
          }
        },
        "required": ["password"]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "description": "Refresh token request",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token issued by login",
            "example": "b2f8d7f6-7d41-4bd0-9b6d-84b0e9d7a1b2",
            "minLength": 1
          }
        },
        "required": ["refreshToken"]
      },
      "ApiResponseTokenRefreshResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/TokenRefreshResponse" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "TokenRefreshResponse": {
        "type": "object",
        "description": "Token refresh response",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "New JWT access token",
            "example": "eyJhbGciOiJIUzI1NiJ9..."
          },
          "tokenType": {
            "type": "string",
            "description": "Token type",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "format": "int64",
            "description": "Access token lifetime in seconds",
            "example": 1800
          }
        },
        "required": ["accessToken", "expiresIn", "tokenType"]
      },
      "LogoutRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token to revoke",
            "minLength": 1
          }
        },
        "required": ["refreshToken"]
      },
      "ApiResponseVoid": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": {},
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "description": "Login request",
        "properties": {
          "username": {
            "type": "string",
            "description": "Username",
            "example": "admin",
            "maxLength": 50,
            "minLength": 3
          },
          "password": {
            "type": "string",
            "description": "Password",
            "example": "123456",
            "maxLength": 100,
            "minLength": 6
          }
        },
        "required": ["password", "username"]
      },
      "ApiResponseLoginResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/LoginResponse" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "description": "Login response containing JWT access token and refresh token",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token",
            "example": "eyJhbGciOiJIUzI1NiJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token",
            "example": "b2f8d7f6-7d41-4bd0-9b6d-84b0e9d7a1b2"
          },
          "tokenType": {
            "type": "string",
            "description": "Token type",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "format": "int64",
            "description": "Access token lifetime in seconds",
            "example": 1800
          }
        },
        "required": ["accessToken", "expiresIn", "refreshToken", "tokenType"]
      },
      "ChangePasswordRequest": {
        "type": "object",
        "description": "Change password request",
        "properties": {
          "oldPassword": {
            "type": "string",
            "description": "Current password",
            "example": "123456",
            "minLength": 1
          },
          "newPassword": {
            "type": "string",
            "description": "New password",
            "example": "new-password",
            "maxLength": 100,
            "minLength": 6
          }
        },
        "required": ["newPassword", "oldPassword"]
      },
      "UpdateUserStatusRequest": {
        "type": "object",
        "description": "Update user status request",
        "properties": {
          "status": {
            "type": "string",
            "description": "New account status",
            "enum": ["ACTIVE", "DISABLED", "LOCKED"],
            "example": "ACTIVE"
          }
        },
        "required": ["status"]
      },
      "Pageable": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "format": "int32", "minimum": 0 },
          "size": { "type": "integer", "format": "int32", "minimum": 1 },
          "sort": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PageResponseUserManagementResponse": {
        "type": "object",
        "description": "Generic page response",
        "properties": {
          "content": {
            "type": "array",
            "description": "Page content",
            "items": { "$ref": "#/components/schemas/UserManagementResponse" }
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "description": "Current zero-based page index",
            "example": 0
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "description": "Page size",
            "example": 20
          },
          "totalElements": {
            "type": "integer",
            "format": "int64",
            "description": "Total element count",
            "example": 42
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "description": "Total page count",
            "example": 3
          }
        }
      },
      "ApiResponseCurrentUserResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/CurrentUserResponse" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "CurrentUserResponse": {
        "type": "object",
        "description": "Current authenticated user response",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "User ID",
            "example": 1
          },
          "username": {
            "type": "string",
            "description": "Username",
            "example": "admin"
          },
          "displayName": {
            "type": "string",
            "description": "Display name",
            "example": "System Administrator"
          },
          "status": {
            "type": "string",
            "description": "User status",
            "enum": ["ACTIVE", "DISABLED", "LOCKED"],
            "example": "ACTIVE"
          },
          "roles": {
            "type": "array",
            "description": "Assigned roles",
            "items": { "$ref": "#/components/schemas/RoleResponse" }
          }
        }
      },
      "RoleResponse": {
        "type": "object",
        "description": "Role response",
        "properties": {
          "code": {
            "type": "string",
            "description": "Role code",
            "example": "ROLE_ADMIN"
          },
          "name": {
            "type": "string",
            "description": "Role display name",
            "example": "Administrator"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "name": "Authorization",
        "in": "header",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
